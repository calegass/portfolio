---
import { defaultLang } from "../i18n/ui";
import { getLocalizedPath, useTranslations } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";

const t = useTranslations(defaultLang);
const home = getLocalizedPath(defaultLang);
---

<Layout title={`404 — ${t("site.title")}`} noindex>
  <main
    class="relative z-10 mx-auto flex min-h-screen w-full max-w-4xl flex-col items-start justify-center px-6 py-8 sm:px-10"
  >
    <p
      class="text-foreground font-serif text-7xl font-semibold leading-none sm:text-8xl"
    >
      404
    </p>
    <h1 class="text-muted mt-6 font-serif text-2xl">{t("notFound.title")}</h1>
    <p class="text-muted mt-2 max-w-xl font-serif text-lg">
      {t("notFound.message")}
    </p>
    <a
      href={home}
      class="text-foreground hover:text-muted mt-8 font-serif font-semibold underline underline-offset-4 transition-colors duration-200"
    >
      {t("notFound.back")}
    </a>
  </main>
</Layout>
