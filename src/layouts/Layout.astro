---
import { ClientRouter } from "astro:transitions";
import CursorBlob from "../components/CursorBlob.astro";
import Footer from "../components/Footer.astro";
import { OG_IMAGE, OG_LOCALE } from "../consts";
import { defaultLang, languages } from "../i18n/ui";
import {
  getLangFromUrl,
  getLocalizedPath,
  getPathWithoutLang,
  useTranslations,
} from "../i18n/utils";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const {
  title = t("site.title"),
  description = t("site.description"),
  noindex = false,
} = Astro.props;

const siteName = t("site.title");
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(OG_IMAGE, Astro.site);

const path = getPathWithoutLang(Astro.url);
const alternates = (Object.keys(languages) as (keyof typeof languages)[]).map(
  (code) => ({
    code,
    href: new URL(getLocalizedPath(code, path), Astro.site).href,
  }),
);
const xDefault =
  alternates.find((alt) => alt.code === defaultLang)?.href ?? canonical.href;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta
      name="theme-color"
      content="#f4f1e8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1b1813"
      media="(prefers-color-scheme: dark)"
    />

    {noindex && <meta name="robots" content="noindex, follow" />}
    {
      !noindex && (
        <Fragment>
          <link rel="canonical" href={canonical} />
          {alternates.map((alt) => (
            <link rel="alternate" hreflang={alt.code} href={alt.href} />
          ))}
          <link rel="alternate" hreflang="x-default" href={xDefault} />
        </Fragment>
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {!noindex && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    {
      alternates
        .filter((alt) => alt.code !== lang)
        .map((alt) => (
          <meta property="og:locale:alternate" content={OG_LOCALE[alt.code]} />
        ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      (() => {
        const themeStorageKey = "theme";

        const getStoredTheme = () => {
          try {
            const theme = window.localStorage.getItem(themeStorageKey);
            return theme === "dark" || theme === "light" ? theme : null;
          } catch {
            return null;
          }
        };

        const theme =
          getStoredTheme() ??
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <title>{title}</title>
    <ClientRouter />
    <style>
      #smooth-content {
        position: relative;
        z-index: 2;
        will-change: transform;
      }
    </style>
  </head>
  <body>
    <div id="smooth-wrapper">
      <CursorBlob />
      <div id="smooth-content">
        <slot />
        <Footer />
      </div>
    </div>
  </body>
</html>
